rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks if the requesting user is authenticated with a whitelisted admin email
    function isWhitelistedAdmin() {
      return request.auth != null 
        && (
          request.auth.token.email.lower() == "mittifiedbusiness@gmail.com" ||
          request.auth.token.email.lower() == "mittifiedbusiness@gamail.com" ||
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
        );
    }

    // Public read-only access for general users. Write access only for admins.
    match /creators/{creatorId} {
      allow read: if true;
      allow write: if isWhitelistedAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isWhitelistedAdmin();
    }

    // Whitelist rules: Users can retrieve their own record to verify their status. 
    // Only whitelisted admins can list all or modify admin records.
    match /admins/{emailId} {
      allow get: if request.auth != null && request.auth.token.email.lower() == emailId;
      allow list, write: if isWhitelistedAdmin();
    }

    // Dynamic config rules: Restrict API keys to admins only.
    match /site_config/api_keys {
      allow read, write: if isWhitelistedAdmin();
    }
    match /site_config/{documentId} {
      allow read: if true;
      allow write: if isWhitelistedAdmin();
    }
  }
}
