rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to media assets (avatars, article thumbnails)
      allow read: if true;

      // Allow write access only if user is authenticated, verified, and whitelisted in Firestore admins collection
      allow write: if request.auth != null 
        && request.auth.token.email_verified == true
        && (
          request.auth.token.email.lower() == 'mittifiedbusiness@gmail.com' ||
          firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email.lower()))
        );
    }
  }
}
